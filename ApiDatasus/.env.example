# Copie este arquivo para .env e preencha os valores antes de executar o pipeline.
# NUNCA commite o arquivo .env no repositório.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Porta 5435 — mapeada pelo docker-compose.yml (5435 no host → 5432 no container)
PGHOST=127.0.0.1
PGPORT=5435
PGDATABASE=maternar
PGUSER=postgres
PGPASSWORD=

# ── Variáveis espelhadas no docker-compose.yml ────────────────────────────────
# (usadas pelo Compose para criar os serviços postgres e rabbitmq)
DB_USER=postgres
DB_PASSWORD=
DB_NAME=maternar
RABBIT_USER=maternar
RABBIT_PASSWORD=
