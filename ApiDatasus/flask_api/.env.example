# =============================================================================
# Maternar — Flask IA Service — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# ── PostgreSQL (banco de dados compartilhado com o backend Next.js) ───────────
PGHOST=127.0.0.1
PGPORT=5435
PGDATABASE=maternar
PGUSER=postgres
PGPASSWORD=GaFeMaPa_2025

# ── RabbitMQ (mensageria) ─────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=maternar
RABBITMQ_PASSWORD=PREENCHER
RABBITMQ_VHOST=/

# Nomes das filas (manter em sincronia com o backend Next.js)
QUEUE_CLASSIFY=maternar.classificar
QUEUE_DLX=maternar.classificar.dlq

# ── Flask HTTP (desenvolvimento / health-check) ───────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=false

# ── Artefatos de ML ───────────────────────────────────────────────────────────
# Caminho base onde os .pkl estão montados (volume Docker ou path absoluto)
MODEL_DIR=/app/models

# Nomes dos arquivos (não alterar em produção)
KMEANS_FILENAME=kmeans_k3.pkl
SCALER_FILENAME=scaler_maternar.pkl
PCA_FILENAME=pca_maternar.pkl
